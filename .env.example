# Copie para .env:  cp .env.example .env

# --- Docker Compose (Postgres + Pact Broker) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pact
POSTGRES_DB=pact

PACT_BROKER_PORT=9292
PACT_BROKER_USERNAME=pact
PACT_BROKER_PASSWORD=pact

# --- TestFlow (provider API) ---
TESTFLOW_PORT=5050

# URLs para testes locais (fora do Docker) — Etapa 2+
PROVIDER_BASE_URL=http://localhost:5050

# Pact — publish, verify, can-i-deploy
# Incremente PACT_CONSUMER_VERSION ao alterar o conteúdo de um pact já publicado.
PACT_BROKER_BASE_URL=http://localhost:9292
PACT_CONSUMER_NAME=testflow-web
PACT_PROVIDER_NAME=sandbox-api
PACT_CONSUMER_VERSION=0.1.2
PACT_CONSUMER_TAG=main
PACT_PROVIDER_VERSION=0.1.1
